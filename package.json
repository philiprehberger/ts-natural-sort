{
  "name": "@philiprehberger/natural-sort",
  "version": "0.1.0",
  "description": "Natural string sorting — file2 before file10, not after",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test"
  },
  "keywords": [
    "sort",
    "natural",
    "compare",
    "order",
    "alphanumeric",
    "natsort"
  ],
  "author": "philiprehberger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-natural-sort.git"
  },
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-natural-sort/issues"
  },
  "homepage": "https://github.com/philiprehberger/ts-natural-sort#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
